                    >
                      Access Student Portal
                    </Button>
                  </CardContent>
                </Card>
              </div>
            </div>
          </section>

          {/* TESTIMONIALS */}
          <section className="py-20 bg-white">
            <div className="max-w-7xl mx-auto px-4">
              <div className="text-center mb-14">
                <span className="text-secondary font-semibold text-sm uppercase tracking-widest">
